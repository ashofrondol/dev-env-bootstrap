# ===== 개발환경 기본 설정 =====
# make가 include하는 파일 (KEY = VALUE 형식)

# 파이썬 버전을 명시하지 않았을 때 사용할 기본값
DEFAULT_PYTHON_VERSION = 3.13

# 프로젝트 기본 언어 (python | web)
# 주의: 로케일 환경변수 LANG 과 충돌하지 않도록 PROJ_LANG 사용
PROJ_LANG = python

# 기본 테스트 프레임워크 (pytest | unittest)
TEST_FRAMEWORK = pytest

# 기본 프로젝트 이름
PROJECT_NAME = my-project

# 블랙박스 그레이더 폴더 이름 (이 저장소의 '바로 위 상위 폴더'에서 이 이름을 찾는다)
# make grade / make grade-detect 가 사용한다.
GRADER_DIRNAME = blackbox-tests
